{
  "name": "@redshirt-sports/studio",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "sanity dev",
    "start": "sanity start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "sanity build",
    "deploy:schema": "sanity schema deploy --manifest-dir ./dist/static",
