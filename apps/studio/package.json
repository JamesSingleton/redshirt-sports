    "@sanity/blueprints": "^0.21.0",
    "@sanity/client": "catalog:",
    "@sanity/dashboard": "^6.0.3",
    "@sanity/functions": "^1.3.1",
    "@sanity/icons": "^3.7.4",
    "@sanity/image-url": "^2.1.1",
    "@sanity/table": "^3.1.3",
    "@sanity/ui": "^3.2.0",
    "@sanity/vision": "^6.2.0",
    "copy-to-clipboard": "^4.0.2",
    "lucide-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "sanity": "catalog:",
    "sanity-plugin-documents-pane": "^4.1.5",
    "sanity-plugin-media": "^5.0.2",
    "slugify": "^1.6.9",
