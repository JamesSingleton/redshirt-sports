{
  "name": "@redshirt-sports/studio",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "sanity dev",
    "start": "sanity start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "build": "sanity build && sanity schema deploy --manifest-dir ./dist/static",
    "deploy": "sanity deploy",
    "type": "sanity schema extract --enforce-required-fields && sanity typegen generate",
    "check:types": "tsc --noEmit"
  },
  "dependencies": {
    "@portabletext/react": "^6.0.3",
    "@sanity/asset-utils": "^2.3.0",
    "@sanity/assist": "^6.0.2",
    "@sanity/blueprints": "^0.13.1",
    "@sanity/client": "^7.17.0",
    "@sanity/dashboard": "^5.0.1",
    "@sanity/functions": "^1.2.1",
    "@sanity/icons": "^3.7.4",
    "@sanity/image-url": "^2.0.3",
    "@sanity/table": "^2.0.1",
    "@sanity/ui": "^3.1.13",
    "@sanity/vision": "^5.14.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sanity": "5.14.1",
    "sanity-plugin-documents-pane": "^3.0.2",
    "sanity-plugin-media": "^4.1.1",
    "slugify": "^1.6.6",
    "styled-components": "^6.3.11"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14"
  }
}
