{
  "name": "@redshirt-sports/studio",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "sanity dev",
    "start": "sanity start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "build": "sanity build && sanity schema deploy --manifest-dir ./dist/static",
    "deploy": "sanity deploy",
    "type": "sanity schema extract --enforce-required-fields && sanity typegen generate",
    "check:types": "tsc --noEmit"
  },
  "dependencies": {
    "@portabletext/react": "^6.0.3",
    "@sanity/asset-utils": "^2.3.0",
    "@sanity/assist": "^6.0.4",
    "@sanity/blueprints": "^0.16.0",
    "@sanity/client": "^7.21.0",
    "@sanity/dashboard": "^5.0.1",
    "@sanity/functions": "^1.3.1",
    "@sanity/icons": "^3.7.4",
    "@sanity/image-url": "^2.1.1",
    "@sanity/table": "^2.0.1",
    "@sanity/ui": "^3.1.14",
    "@sanity/vision": "^5.22.0",
    "lucide-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "sanity": "^5.22.0",
    "sanity-plugin-documents-pane": "^3.0.2",
    "sanity-plugin-media": "^4.2.0",
    "slugify": "^1.6.9",
    "styled-components": "^6.4.1"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:"
  }
