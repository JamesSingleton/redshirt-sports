    "check:types": "turbo check:types"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@redshirt-sports/typescript-config": "workspace:*",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3"
  }
