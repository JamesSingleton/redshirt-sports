{
  "name": "@redshirt-sports/root",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.34.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "biome format --write .",
    "check:format": "biome check .",
    "check:types": "turbo run check:types",
    "ci": "turbo run lint check:types test --affected"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@redshirt-sports/typescript-config": "workspace:*",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3"
  }
}
